---
// Hero.astro
import VerionChip from "./VerionChip.astro";
---

<section
    class="relative min-h-[100svh] md:h-screen px-8 lg:px-12 pt-32 md:pt-44 pb-16 section-connector overflow-hidden"
>
    <!-- Ambient top glow -->
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] pointer-events-none"
        style="background: radial-gradient(ellipse at center, rgba(0, 212, 255, 0.04) 0%, transparent 70%); filter: blur(60px);"
    >
    </div>

    <!-- Corner accent lines -->
    <div
        class="absolute top-24 left-6 w-20 h-px bg-gradient-to-r from-verion-accent/40 to-transparent"
    >
    </div>
    <div
        class="absolute top-24 left-6 w-px h-20 bg-gradient-to-b from-verion-accent/40 to-transparent"
    >
    </div>

    <!-- Right: Chip animation — absolutely positioned, spans full section height -->
    <div
        class="absolute inset-y-0 right-12 w-[40%] hidden md:block animate-fade-in pointer-events-none"
        style="animation-delay: 0.3s;"
    >
        <VerionChip width="100%" height="100%" />
    </div>

    <!-- Left: Text content — normal flow, anchored near top -->
    <div class="relative w-full max-w-7xl mx-auto">
        <div class="max-w-[780px]">
            <h1
                class="hero-headline text-verion-heading animate-fade-in"
                style="animation-delay: 0.1s;"
            >
                Silicon design,<br /><span class="text-verion-accent text-glow"
                    >accelerated.</span
                >
            </h1>

            <p
                class="hero-subhead mt-8 text-verion-subtle animate-fade-in"
                style="animation-delay: 0.2s;"
            >
                RTL regression in minutes, not days. Same Verilog. Same
                testbenches. 10&ndash;50x faster regressions.
            </p>
        </div>

        <!-- Mobile chip — visible below text on small screens -->
        <div
            class="md:hidden mt-12 max-w-xs mx-auto animate-fade-in pointer-events-none"
            style="animation-delay: 0.3s;"
            aria-hidden="true"
        >
            <VerionChip width="100%" height="100%" />
        </div>
    </div>
</section>

<style>
    .hero-headline {
        font-family: "Inter", system-ui, sans-serif;
        font-weight: 400;
        font-size: clamp(2.5rem, 6vw, 5.75rem);
        line-height: 1.04;
        letter-spacing: -0.035em;
    }

    @media (min-width: 768px) {
        .hero-headline {
            white-space: nowrap;
        }
    }

    .hero-subhead {
        font-family: "Inter", system-ui, sans-serif;
        font-weight: 400;
        font-size: 1rem;
        line-height: 1.55;
        letter-spacing: -0.01em;
        max-width: 36rem;
    }
</style>
