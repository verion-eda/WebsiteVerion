---
// Hero.astro
---

<section
    class="relative pt-48 pb-40 px-6 border-b border-verion-border overflow-hidden"
>
    <!-- Ambient glow -->
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-verion-accent/[0.04] rounded-full blur-[120px] pointer-events-none"
    >
    </div>

    <div class="relative max-w-6xl mx-auto">
        <p
            class="font-mono text-xs text-verion-accent uppercase tracking-widest mb-10 animate-fade-in"
        >
            Now accepting design teams
        </p>

        <h1
            class="text-5xl md:text-7xl lg:text-8xl font-bold text-verion-heading leading-[1.02] tracking-tight max-w-5xl animate-fade-in"
            style="animation-delay: 0.1s;"
        >
            Silicon design,<br />accelerated.
        </h1>

        <p
            class="mt-10 text-lg md:text-xl text-verion-subtle max-w-xl leading-relaxed animate-fade-in"
            style="animation-delay: 0.2s;"
        >
            Verion replaces your CPU-based RTL simulator with a GPU-native
            engine. Same Verilog. Same testbenches. 10&ndash;50x faster
            regressions.
        </p>

        <div class="mt-14 animate-fade-in" style="animation-delay: 0.3s;">
            <a
                href="#waitlist"
                class="group inline-flex items-center gap-3 font-mono text-sm text-verion-accent border border-verion-accent/30 px-7 py-3.5 hover:bg-verion-accent/10 hover:border-verion-accent/60 transition-all duration-300"
            >
                Request access
                <span
                    class="transition-transform duration-300 group-hover:translate-x-1"
                    >&rarr;</span
                >
            </a>
        </div>
    </div>
</section>
