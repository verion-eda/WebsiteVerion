---
// Team.astro

const team = [
    {
        name: "Daniel Kiesewalter",
        role: "Co-founder",
        bio: "Sony AI chip design engineer. Deep expertise in semiconductor verification and hardware architecture.",
        initials: "DK",
    },
    {
        name: "Yves Inneichen",
        role: "Co-founder",
        bio: "ACM Gordon Bell Prize winner. Background in high-performance computing and GPU-accelerated systems.",
        initials: "YI",
    },
];
---

<section id="team" class="py-40 px-6 border-b border-verion-border">
    <div class="max-w-6xl mx-auto">
        <div class="reveal">
            <p
                class="font-mono text-xs text-verion-accent uppercase tracking-widest mb-6"
            >
                Team
            </p>

            <h2
                class="text-3xl md:text-5xl lg:text-6xl font-bold text-verion-heading max-w-3xl leading-tight tracking-tight"
            >
                Semiconductor engineers building for semiconductor engineers.
            </h2>
        </div>

        <div
            class="mt-20 grid md:grid-cols-2 gap-px bg-verion-border max-w-3xl reveal"
        >
            {
                team.map((member) => (
                    <div class="bg-verion-bg p-8 md:p-10 card-hover">
                        <div class="w-12 h-12 border border-verion-border flex items-center justify-center font-mono text-xs text-verion-muted mb-6">
                            {member.initials}
                        </div>
                        <h3 class="text-white font-medium text-lg">
                            {member.name}
                        </h3>
                        <p class="font-mono text-xs text-verion-accent mt-1.5 mb-5">
                            {member.role}
                        </p>
                        <p class="text-sm text-verion-muted leading-relaxed">
                            {member.bio}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
