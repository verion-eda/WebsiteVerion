---
// Product.astro

const features = [
    {
        title: "Cycle-accurate simulation",
        description:
            "Full-cycle, cycle-accurate execution with multi-GPU scaling.",
    },
    {
        title: "Fast compile & iterate",
        description:
            "Fast compile times, save/restore, and dynamic stimulus reconfiguration.",
    },
    {
        title: "Coverage built in",
        description: "Code coverage metrics out of the box. No extra tooling.",
    },
    {
        title: "Open ecosystem",
        description:
            "Open at core. Inspect it, build on it, integrate it. No vendor lock-in.",
    },
];

const integration = [
    { label: "Interfaces", items: "DPI, VPI, SCE-MI, UVM" },
    { label: "APIs", items: "Python, Rust, C++" },
    { label: "Hardware", items: "Nvidia, Apple Metal" },
];

const tableRows = [
    {
        metric: "Speed",
        cpu: "1x (Baseline)",
        fpga: "Fastest",
        verion: "10x–100x",
    },
    {
        metric: "Compile time",
        cpu: "Minutes",
        fpga: "Hours to days",
        verion: "Minutes",
    },
    {
        metric: "Cost",
        cpu: "Low",
        fpga: "Very high",
        verion: "Medium",
    },
    {
        metric: "RTL change turnaround",
        cpu: "Fast",
        fpga: "Moderate",
        verion: "Fast",
    },
    {
        metric: "Cloud scalability",
        cpu: "Native",
        fpga: "Limited",
        verion: "Native",
    },
];
---

<section id="product" class="py-28 px-8 lg:px-12 section-connector">
    <div class="max-w-7xl mx-auto">
        <div class="reveal">
            <p
                class="font-mono text-xs text-verion-accent uppercase tracking-widest mb-6 text-glow-subtle"
            >
                // Product
            </p>

            <h2
                class="text-3xl md:text-5xl lg:text-6xl font-bold text-verion-heading max-w-3xl leading-tight tracking-tight"
            >
                Drop-in GPU simulation.<br />No rewrites required.
            </h2>
            <p
                class="mt-6 text-verion-subtle max-w-2xl leading-relaxed text-lg"
            >
                Verion's compiler maps standard Verilog and SystemVerilog onto
                GPU clusters automatically. The irregular branching of chip
                logic is partitioned and parallelized — unlocking throughput
                that CPU simulators cannot match.
            </p>
        </div>

        <!-- Comparison table -->
        <div
            class="mt-24 border border-verion-accent/15 overflow-hidden border-glow reveal"
        >
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr
                            class="border-b border-verion-accent/10 bg-verion-surface/50"
                        >
                            <th
                                class="text-left px-6 py-5 font-mono text-xs text-verion-muted uppercase tracking-wider"
                            ></th>
                            <th
                                class="text-left px-6 py-5 font-mono text-xs text-verion-muted uppercase tracking-wider"
                                >CPU Sim</th
                            >
                            <th
                                class="text-left px-6 py-5 font-mono text-xs text-verion-muted uppercase tracking-wider"
                                >FPGA</th
                            >
                            <th
                                class="text-left px-6 py-5 font-mono text-xs text-verion-accent uppercase tracking-wider bg-verion-accent/5 text-glow-subtle"
                                >Verion</th
                            >
                        </tr>
                    </thead>
                    <tbody>
                        {
                            tableRows.map((row) => (
                                <tr class="border-b border-verion-border/50 last:border-b-0 hover:bg-verion-accent/[0.02] transition-colors">
                                    <td class="px-6 py-4 text-white font-medium">
                                        {row.metric}
                                    </td>
                                    <td class="px-6 py-4 text-verion-muted">
                                        {row.cpu}
                                    </td>
                                    <td class="px-6 py-4 text-verion-muted">
                                        {row.fpga}
                                    </td>
                                    <td class="px-6 py-4 text-verion-accent font-mono bg-verion-accent/5">
                                        {row.verion}
                                    </td>
                                </tr>
                            ))
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Features -->
        <div class="mt-32 reveal">
            <p
                class="font-mono text-xs text-verion-muted uppercase tracking-widest mb-14"
            >
                // Capabilities
            </p>
            <div
                class="grid md:grid-cols-2 gap-px bg-verion-border/50 border border-verion-accent/10 border-glow"
            >
                {
                    features.map((f, i) => (
                        <div class="bg-verion-bg p-8 md:p-10 card-glow">
                            <span class="font-mono text-xs text-verion-accent/40">
                                {String(i + 1).padStart(2, "0")}
                            </span>
                            <h3 class="text-white font-medium mt-3 mb-3">
                                {f.title}
                            </h3>
                            <p class="text-sm text-verion-muted leading-relaxed">
                                {f.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Integration -->
        <div class="mt-32 reveal">
            <p
                class="font-mono text-xs text-verion-muted uppercase tracking-widest mb-4"
            >
                // Integration
            </p>
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-12">
                Works with your existing flow.
            </h3>
            <div
                class="grid md:grid-cols-3 gap-px bg-verion-border/50 border border-verion-accent/10 border-glow"
            >
                {
                    integration.map((ig) => (
                        <div class="bg-verion-bg p-6 md:p-8 card-glow">
                            <p class="font-mono text-xs text-verion-accent uppercase tracking-widest mb-4 text-glow-subtle">
                                {ig.label}
                            </p>
                            <p class="text-sm text-verion-subtle font-mono">
                                {ig.items}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>
