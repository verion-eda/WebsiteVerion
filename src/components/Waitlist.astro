---
// Waitlist.astro
---

<section
    id="waitlist"
    class="relative py-40 px-8 lg:px-12 section-connector overflow-hidden"
>
    <!-- Ares ambient glow -->
    <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[700px] h-[500px] pointer-events-none"
        style="background: radial-gradient(ellipse at center, rgba(0, 212, 255, 0.06) 0%, rgba(0, 136, 255, 0.02) 50%, transparent 70%); filter: blur(80px);"
    >
    </div>

    <div class="relative max-w-7xl mx-auto">
        <div class="reveal">
            <p
                class="font-mono text-xs text-verion-accent uppercase tracking-widest mb-6 text-glow-subtle"
            >
                Get started
            </p>

            <h2
                class="text-3xl md:text-5xl lg:text-6xl font-bold text-verion-heading leading-tight tracking-tight max-w-3xl"
            >
                Run your next regression on <span
                    class="text-verion-accent text-glow">Verion.</span
                >
            </h2>
            <p class="mt-6 text-verion-subtle max-w-md text-lg">
                We're onboarding select design teams. Tell us about your
                workload.
            </p>
        </div>

        <div class="mt-14 reveal">
            <a
                href="mailto:contact@verion-eda.com"
                class="btn-neon group inline-flex items-center gap-3 font-mono text-sm text-verion-accent border border-verion-accent/40 px-7 py-3.5 hover:bg-verion-accent/10 hover:border-verion-accent/80 transition-all duration-300"
            >
                contact@verion-eda.com
                <span
                    class="transition-transform duration-300 group-hover:translate-x-1"
                    >&rarr;</span
                >
            </a>
        </div>
    </div>
</section>
