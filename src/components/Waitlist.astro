---
// Waitlist.astro
---

<section id="waitlist" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="bg-brand-500 rounded-2xl px-8 py-16 text-center md:px-16">

      <h2 class="text-3xl md:text-4xl font-semibold text-white leading-snug">
        Ready to try Verion on your next regression run?
      </h2>
      <p class="mt-4 text-brand-100 max-w-md mx-auto">
        Get in touch and we'll set you up with early access.
      </p>

      <div class="mt-8">
        <a
          href="mailto:contact@verion-eda.com"
          class="inline-flex items-center gap-2 bg-white text-brand-600 font-medium px-8 py-3.5 rounded-lg text-sm hover:bg-brand-50 transition-colors"
        >
          contact@verion-eda.com
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
