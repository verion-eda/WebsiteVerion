---
// Waitlist.astro
---

<section
    id="waitlist"
    class="relative py-40 px-6 border-b border-verion-border overflow-hidden"
>
    <!-- Ambient glow -->
    <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-verion-accent/[0.03] rounded-full blur-[100px] pointer-events-none"
    >
    </div>

    <div class="relative max-w-6xl mx-auto">
        <div class="reveal">
            <p
                class="font-mono text-xs text-verion-accent uppercase tracking-widest mb-6"
            >
                Get started
            </p>

            <h2
                class="text-3xl md:text-5xl lg:text-6xl font-bold text-verion-heading leading-tight tracking-tight max-w-3xl"
            >
                Run your next regression on Verion.
            </h2>
            <p class="mt-6 text-verion-subtle max-w-md text-lg">
                We're onboarding select design teams. Tell us about your
                workload.
            </p>
        </div>

        <div class="mt-14 reveal">
            <a
                href="mailto:contact@verion-eda.com"
                class="group inline-flex items-center gap-3 font-mono text-sm text-verion-accent border border-verion-accent/30 px-7 py-3.5 hover:bg-verion-accent/10 hover:border-verion-accent/60 transition-all duration-300"
            >
                contact@verion-eda.com
                <span
                    class="transition-transform duration-300 group-hover:translate-x-1"
                    >&rarr;</span
                >
            </a>
        </div>
    </div>
</section>
