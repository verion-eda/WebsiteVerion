---
// CodeExample.astro — Tabbed code block showing simulator usage in Rust, C++, Python

const tabs = ["Rust", "C++", "Python"];

const code = {
    rust: `use verion_simulator::SimulatorBuilder;

fn main() -> anyhow::Result<()> {
    let mut dut = SimulatorBuilder::new()
    .build()?;

    dut.reset();

    dut.poke_signal("a", true)?;
    dut.poke_signal("b", true)?;
    dut.step();

    let sum = dut.peek_signal("sum")?;
    let carry = dut.peek_signal("carry")?;
    println!("sum={}, carry={}", sum, carry);

    dut.sync();

    Ok(())
}`,
    cpp: `#include "verion.h"
#include <stdio.h>

int main() {
    SimResult res = sim_create();

    res = sim_reset(res.handle);

    sim_poke_signal(res.handle, "a", true);
    sim_poke_signal(res.handle, "b", true);
    res = sim_step(res.handle);

    uint64_t sum, carry;
    sim_peek_signal(res.handle, "sum", &sum);
    sim_peek_signal(res.handle, "carry", &carry);
    printf("sum=%llu, carry=%llu\\n", sum, carry);

    sim_dump(res.handle, "dump.vcd");

    return 0;
}`,
    python: `from verion import Simulator

sim = Simulator(
    device_id=0,
)

sim.reset()

sim.poke_signal("a", True)
sim.poke_signal("b", True)
sim.step()

sum_val = sim.peek_signal("sum")
carry = sim.peek_signal("carry")
print(f"sum={sum_val}, carry={carry}")

sim.sync()`,
};
---

<section class="py-28 px-8 lg:px-12 section-connector">
    <div class="max-w-7xl mx-auto">
        <div class="reveal">
            <p
                class="font-mono text-xs text-verion-accent uppercase tracking-widest mb-6 text-glow-subtle"
            >
                // Developer experience
            </p>

            <h2
                class="text-3xl md:text-5xl lg:text-6xl font-bold text-verion-heading max-w-3xl leading-tight tracking-tight"
            >
                A few lines to launch<br />a regression.
            </h2>
            <p class="mt-6 text-verion-subtle max-w-xl leading-relaxed text-lg">
                Native SDKs for Rust, C++, and Python. Load your design, run
                simulation, extract results — all programmatic.
            </p>
        </div>

        <!-- Code viewer -->
        <div
            class="mt-20 border border-verion-accent/15 bg-verion-surface overflow-hidden border-glow shadow-neon-red reveal"
            id="code-viewer"
        >
            <!-- Terminal title bar -->
            <div
                class="flex items-center justify-between border-b border-verion-accent/10 bg-verion-bg/80 px-6 py-3"
            >
                <div class="flex items-center gap-2">
                    <div
                        class="w-3 h-3 rounded-full bg-verion-accent/30 border border-verion-accent/40"
                    >
                    </div>
                    <div
                        class="w-3 h-3 rounded-full bg-verion-orange/20 border border-verion-orange/30"
                    >
                    </div>
                    <div
                        class="w-3 h-3 rounded-full bg-verion-amber/15 border border-verion-amber/25"
                    >
                    </div>
                </div>
                <span
                    class="font-mono text-[10px] text-verion-muted/50 uppercase tracking-widest"
                    >verion simulator</span
                >
                <div class="w-16"></div>
            </div>

            <!-- Tabs -->
            <div class="flex border-b border-verion-accent/10 bg-verion-bg/50">
                {
                    tabs.map((tab, i) => (
                        <button
                            data-tab={tab.toLowerCase().replace("++", "pp")}
                            class={`px-6 py-4 font-mono text-xs uppercase tracking-wider transition-all duration-200 ${
                                i === 0
                                    ? "text-verion-accent border-b-2 border-verion-accent -mb-px text-glow-subtle"
                                    : "text-verion-muted hover:text-verion-accent/70"
                            }`}
                        >
                            {tab}
                        </button>
                    ))
                }
            </div>

            <!-- Code panels -->
            <div class="relative">
                <div
                    data-panel="rust"
                    data-full-code={code.rust}
                    class="code-panel"
                >
                    <pre
                        class="p-6 md:p-10 overflow-x-auto text-sm font-mono leading-relaxed text-verion-subtle"
                        aria-hidden="true"><span class="code-sizer">{code.rust}</span></pre>
                    <pre
                        class="code-overlay p-6 md:p-10 text-sm font-mono leading-relaxed text-verion-subtle"><code /><span class="typing-cursor">▌</span></pre>
                </div>

                <div
                    data-panel="cpp"
                    data-full-code={code.cpp}
                    class="code-panel hidden"
                >
                    <pre
                        class="p-6 md:p-10 overflow-x-auto text-sm font-mono leading-relaxed text-verion-subtle"
                        aria-hidden="true"><span class="code-sizer">{code.cpp}</span></pre>
                    <pre
                        class="code-overlay p-6 md:p-10 text-sm font-mono leading-relaxed text-verion-subtle"><code /><span class="typing-cursor">▌</span></pre>
                </div>

                <div
                    data-panel="python"
                    data-full-code={code.python}
                    class="code-panel hidden"
                >
                    <pre
                        class="p-6 md:p-10 overflow-x-auto text-sm font-mono leading-relaxed text-verion-subtle"
                        aria-hidden="true"><span class="code-sizer">{code.python}</span></pre>
                    <pre
                        class="code-overlay p-6 md:p-10 text-sm font-mono leading-relaxed text-verion-subtle"><code /><span class="typing-cursor">▌</span></pre>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .code-panel {
        position: relative;
    }
    .code-sizer {
        visibility: hidden;
    }
    .code-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
    }
    .typing-cursor {
        color: rgba(0, 212, 255, 0.8);
        animation: blink 0.6s step-end infinite;
    }
    @keyframes blink {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0;
        }
    }
</style>

<script>
    const viewer = document.getElementById("code-viewer");
    if (viewer) {
        const buttons =
            viewer.querySelectorAll<HTMLButtonElement>("[data-tab]");
        const panels = viewer.querySelectorAll<HTMLDivElement>("[data-panel]");

        let currentAnim: number | null = null;

        function typeCode(panel: HTMLDivElement) {
            // Cancel any running animation
            if (currentAnim !== null) {
                cancelAnimationFrame(currentAnim);
                currentAnim = null;
            }

            const fullCode = panel.dataset.fullCode || "";
            const overlay = panel.querySelector(".code-overlay")!;
            const codeEl = overlay.querySelector("code")!;
            const cursor = overlay.querySelector(
                ".typing-cursor",
            ) as HTMLElement;

            codeEl.textContent = "";
            if (cursor) cursor.style.display = "inline";

            let i = 0;
            const charDelay = 12; // ms per character
            let lastTime = 0;

            function step(timestamp: number) {
                if (!lastTime) lastTime = timestamp;
                const elapsed = timestamp - lastTime;
                // Type multiple chars per frame to keep up at 12ms/char
                const charsToType = Math.max(
                    1,
                    Math.floor(elapsed / charDelay),
                );

                if (i < fullCode.length) {
                    const end = Math.min(i + charsToType, fullCode.length);
                    codeEl.textContent += fullCode.slice(i, end);
                    i = end;
                    lastTime = timestamp;
                    currentAnim = requestAnimationFrame(step);
                } else {
                    // Done typing — keep cursor blinking for a moment, then hide
                    currentAnim = null;
                    setTimeout(() => {
                        if (cursor) cursor.style.display = "none";
                    }, 2000);
                }
            }

            currentAnim = requestAnimationFrame(step);
        }

        // Tab switching
        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const target = btn.dataset.tab;

                buttons.forEach((b) => {
                    b.classList.remove(
                        "text-verion-accent",
                        "border-b-2",
                        "border-verion-accent",
                        "-mb-px",
                        "text-glow-subtle",
                    );
                    b.classList.add("text-verion-muted");
                });
                btn.classList.add(
                    "text-verion-accent",
                    "border-b-2",
                    "border-verion-accent",
                    "-mb-px",
                    "text-glow-subtle",
                );
                btn.classList.remove("text-verion-muted");

                panels.forEach((p) => {
                    const isTarget = p.dataset.panel === target;
                    p.classList.toggle("hidden", !isTarget);
                    if (isTarget) typeCode(p);
                });
            });
        });

        // Trigger typing when section scrolls into view
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        // Type the first visible panel
                        const active = viewer.querySelector<HTMLDivElement>(
                            "[data-panel]:not(.hidden)",
                        );
                        if (active) typeCode(active);
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.3 },
        );
        observer.observe(viewer);
    }
</script>
