---
// Problem.astro

const usps = [
    {
        title: "10x – 50x faster",
        description:
            "Outperforms CPU simulators on regressions. Ship silicon faster.",
    },
    {
        title: "Your IP stays yours",
        description:
            "Runs on-premise or in your cloud. Design data never leaves your infrastructure.",
    },
    {
        title: "Full observability",
        description:
            "Complete debug traces and coverage metrics. No FPGA black boxes.",
    },
];

const audiences = [
    {
        label: "IC Startups",
        description:
            "Emulator-grade throughput without the massive CapEx. Scale on cloud GPUs.",
    },
    {
        label: "Fabless Design Teams",
        description:
            "Shrink the regression wall. Run more iterations before tape-out.",
    },
    {
        label: "Hyperscalers",
        description:
            "Put idle GPU clusters to work on chip verification between AI training jobs.",
    },
];
---

<section id="problem" class="py-28 px-8 lg:px-12 section-connector">
    <div class="max-w-7xl mx-auto">
        <div class="reveal">
            <p
                class="font-mono text-xs text-verion-accent uppercase tracking-widest mb-6 text-glow-subtle"
            >
                Why Verion
            </p>

            <h2
                class="text-3xl md:text-5xl lg:text-6xl font-bold text-verion-heading max-w-3xl leading-tight tracking-tight"
            >
                Chip design has outgrown its tools.
            </h2>
            <p class="mt-6 text-verion-subtle max-w-xl leading-relaxed text-lg">
                Design complexity doubles every generation. Simulation
                infrastructure hasn't kept up. Verion closes the gap.
            </p>
        </div>

        <div
            class="mt-24 grid md:grid-cols-3 gap-px bg-verion-border/50 border border-verion-accent/10 border-glow reveal"
        >
            {
                usps.map((u, i) => (
                    <div
                        class={`bg-verion-bg p-8 md:p-10 card-glow reveal-delay-${i + 1}`}
                    >
                        <h3 class="font-mono text-sm text-verion-accent uppercase tracking-wide mb-4 text-glow-subtle">
                            {u.title}
                        </h3>
                        <p class="text-sm text-verion-subtle leading-relaxed">
                            {u.description}
                        </p>
                    </div>
                ))
            }
        </div>

        <div class="mt-32 reveal">
            <p
                class="font-mono text-xs text-verion-muted uppercase tracking-widest mb-12"
            >
                Built for
            </p>
            <div class="grid md:grid-cols-3 gap-16">
                {
                    audiences.map((a) => (
                        <div class="border-l border-verion-border hover:border-verion-accent/60 pl-6 transition-all duration-300 hover:shadow-neon-red">
                            <h3 class="text-white font-medium mb-3">
                                {a.label}
                            </h3>
                            <p class="text-sm text-verion-muted leading-relaxed">
                                {a.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>
