---
// Problem.astro — USP cards + Who It's For

const usps = [
  {
    icon: "⚡",
    title: "10x – 50x Faster",
    description: "Faster than VCS and Xcelium. More regression cycles before tape-out.",
  },
  {
    icon: "🔒",
    title: "Your IP, Your Infrastructure",
    description: "On-premise or cloud. Your design data never leaves your control.",
  },
  {
    icon: "🔍",
    title: "Full Visibility",
    description: "Full debug traces and coverage metrics. No FPGA black boxes.",
  },
];

const audiences = [
  {
    label: "IC & Silicon Startups",
    description: "Emulator-grade performance without the $5M–$10M CapEx. Scale on cloud GPUs, pay as you go.",
  },
  {
    label: "Fabless Design Teams",
    description: "Shrink your regression wall. Run more iterations before tape-out.",
  },
  {
    label: "Hyperscalers",
    description: "Your GPU cluster sits idle between AI jobs. Put it to work on chip verification.",
  },
];
---

<section id="problem" class="py-24 px-6 bg-gray-50">
  <div class="max-w-5xl mx-auto">

    <!-- Section label -->
    <p class="text-xs font-medium text-brand-500 uppercase tracking-widest mb-4">Why Verion</p>

    <h2 class="text-3xl md:text-4xl font-semibold text-gray-900 max-w-2xl leading-snug">
      The simulation performance modern chip design demands.
    </h2>
    <p class="mt-4 text-gray-500 max-w-xl">
      Built for the pace of modern semiconductor development.
    </p>

    <!-- USP cards -->
    <div class="mt-14 grid md:grid-cols-3 gap-6">
      {usps.map((u) => (
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <div class="text-2xl mb-4">{u.icon}</div>
          <h3 class="font-semibold text-gray-900 mb-2">{u.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{u.description}</p>
        </div>
      ))}
    </div>

    <!-- Who It's For -->
    <div class="mt-20">
      <p class="text-xs font-medium text-brand-500 uppercase tracking-widest mb-4">Who it's for</p>
      <div class="grid md:grid-cols-3 gap-6">
        {audiences.map((a) => (
          <div class="border-l-2 border-brand-500 pl-5">
            <h3 class="font-semibold text-gray-900 mb-1">{a.label}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{a.description}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
