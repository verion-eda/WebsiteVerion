---
interface Props {
  width?: string;
  height?: string;
  showControls?: boolean;
}

const {
  width = '100%',
  height = '500px',
  showControls = false,
} = Astro.props;
---

<div class="tron-chip-wrapper" style={`width: ${width}; height: ${height}; position: relative; background: transparent; overflow: hidden;`}>
  {showControls && (
    <div class="tron-chip-ui">
      <button class="tron-btn" id="tron-scatter-btn">PULSE</button>
    </div>
  )}
  <canvas class="tron-chip-canvas" style="display:block; width:100%; height:100%;"></canvas>
</div>

<style>
  .tron-chip-wrapper * { box-sizing: border-box; }

  .tron-chip-ui {
    position: absolute;
    top: 12px;
    right: 12px;
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .tron-btn {
    background: transparent;
    border: 1px solid rgba(0, 212, 255, 0.25);
    color: #00d4ff;
    font-size: 10px;
    font-family: 'JetBrains Mono', monospace;
    padding: 5px 12px;
    cursor: pointer;
    letter-spacing: 2px;
    transition: background 0.2s, border-color 0.2s;
  }

  .tron-btn:hover {
    background: rgba(0, 212, 255, 0.12);
    border-color: #00d4ff;
  }
</style>

<script>
  import { gsap } from 'gsap';

  (function () {
    const wrapper = document.querySelector('.tron-chip-wrapper') as HTMLElement | null;
    const canvas  = wrapper?.querySelector('.tron-chip-canvas') as HTMLCanvasElement | null;
    if (!wrapper || !canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const BASE = '0, 212, 255';
    const WARM = '160, 240, 255';
    const rgba = (c: string, a: number) => `rgba(${c}, ${a})`;

    const BLOOM_RADIUS = 200;

    const smoothMouse = { x: -9999, y: -9999 };
    const mouseToX = gsap.quickTo(smoothMouse, 'x', { duration: 0.35, ease: 'power3.out' });
    const mouseToY = gsap.quickTo(smoothMouse, 'y', { duration: 0.35, ease: 'power3.out' });

    type Block = {
      x: number; y: number; w: number; h: number;
      cx: number; cy: number;
      density: number; label: string;
      dots: { x: number; y: number; phase: number; base: number }[];
      activity: number;
      phase: number;
    };

    type Pin = {
      side: number;
      x1: number; y1: number; x2: number; y2: number;
      phase: number;
    };

    type Geo = {
      pkg: { x: number; y: number; w: number; h: number; r: number };
      die: { x: number; y: number; w: number; h: number; r: number };
      blocks: Block[];
      pins: Pin[];
      fieldDots: { x: number; y: number; base: number; phase: number }[];
      size: number;
    };

    let W = 0, H = 0, dpr = 1;
    let geo: Geo | null = null;
    let animId: number | null = null;
    let running = false;
    let lastActivity = 0;
    const IDLE_MS = 1500;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      W = wrapper!.offsetWidth;
      H = wrapper!.offsetHeight;
      canvas!.width  = Math.floor(W * dpr);
      canvas!.height = Math.floor(H * dpr);
      canvas!.style.width  = W + 'px';
      canvas!.style.height = H + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      geo = buildGeometry();
    }

    function buildGeometry(): Geo {
      const size = Math.min(W, H) * 0.86;
      const cx = W / 2;
      const cy = H / 2;

      const pkg = {
        x: cx - size / 2,
        y: cy - size / 2,
        w: size,
        h: size,
        r: size * 0.035,
      };

      const dieInset = size * 0.11;
      const die = {
        x: pkg.x + dieInset,
        y: pkg.y + dieInset,
        w: pkg.w - dieInset * 2,
        h: pkg.h - dieInset * 2,
        r: size * 0.012,
      };

      // Functional blocks laid out to evoke a real die photograph:
      // a large compute core, cache, IO, memory controller, DMA, PHY.
      const rawBlocks = [
        { nx: 0.03, ny: 0.03, nw: 0.54, nh: 0.55, density: 0.55, label: 'CORE' },
        { nx: 0.61, ny: 0.03, nw: 0.36, nh: 0.26, density: 0.82, label: 'L2'   },
        { nx: 0.61, ny: 0.32, nw: 0.36, nh: 0.26, density: 0.58, label: 'IO'   },
        { nx: 0.03, ny: 0.62, nw: 0.28, nh: 0.35, density: 0.7,  label: 'MEM'  },
        { nx: 0.34, ny: 0.62, nw: 0.24, nh: 0.35, density: 0.52, label: 'DMA'  },
        { nx: 0.61, ny: 0.62, nw: 0.36, nh: 0.35, density: 0.62, label: 'PHY'  },
      ];

      const blocks: Block[] = rawBlocks.map(b => {
        const x = die.x + b.nx * die.w;
        const y = die.y + b.ny * die.h;
        const w = b.nw * die.w;
        const h = b.nh * die.h;
        const step = Math.max(3.5, size * 0.014);
        const dots: Block['dots'] = [];
        for (let dx = step / 2; dx < w - step / 2; dx += step) {
          for (let dy = step / 2; dy < h - step / 2; dy += step) {
            if (Math.random() < b.density) {
              dots.push({
                x: x + dx + (Math.random() - 0.5) * 0.8,
                y: y + dy + (Math.random() - 0.5) * 0.8,
                phase: Math.random() * Math.PI * 2,
                base: 0.2 + Math.random() * 0.55,
              });
            }
          }
        }
        return {
          x, y, w, h,
          cx: x + w / 2,
          cy: y + h / 2,
          density: b.density,
          label: b.label,
          dots,
          activity: 0,
          phase: Math.random() * Math.PI * 2,
        };
      });

      // Pins: 16 per side, thin, with short traces extending outside the package.
      const pinsPerSide = 16;
      const pinLen = size * 0.07;
      const pinInset = size * 0.12;
      const pins: Pin[] = [];
      for (let side = 0; side < 4; side++) {
        for (let i = 0; i < pinsPerSide; i++) {
          const t = (i + 0.5) / pinsPerSide;
          let x1 = 0, y1 = 0, x2 = 0, y2 = 0;
          if (side === 0) {
            const px = pkg.x + pinInset + t * (pkg.w - pinInset * 2);
            x1 = x2 = px;
            y1 = pkg.y - pinLen;
            y2 = pkg.y;
          } else if (side === 1) {
            const py = pkg.y + pinInset + t * (pkg.h - pinInset * 2);
            x1 = pkg.x + pkg.w + pinLen;
            x2 = pkg.x + pkg.w;
            y1 = y2 = py;
          } else if (side === 2) {
            const px = pkg.x + pinInset + t * (pkg.w - pinInset * 2);
            x1 = x2 = px;
            y1 = pkg.y + pkg.h + pinLen;
            y2 = pkg.y + pkg.h;
          } else {
            const py = pkg.y + pinInset + t * (pkg.h - pinInset * 2);
            x1 = pkg.x - pinLen;
            x2 = pkg.x;
            y1 = y2 = py;
          }
          pins.push({ side, x1, y1, x2, y2, phase: Math.random() * Math.PI * 2 });
        }
      }

      // Background field: faint grid dots outside the package
      const fieldDots: Geo['fieldDots'] = [];
      const fstep = Math.max(26, size * 0.06);
      const pad = pinLen + 14;
      for (let fx = fstep / 2; fx < W; fx += fstep) {
        for (let fy = fstep / 2; fy < H; fy += fstep) {
          const inside =
            fx > pkg.x - pad && fx < pkg.x + pkg.w + pad &&
            fy > pkg.y - pad && fy < pkg.y + pkg.h + pad;
          if (inside) continue;
          fieldDots.push({
            x: fx + (Math.random() - 0.5) * 2,
            y: fy + (Math.random() - 0.5) * 2,
            base: 0.04 + Math.random() * 0.1,
            phase: Math.random() * Math.PI * 2,
          });
        }
      }

      return { pkg, die, blocks, pins, fieldDots, size };
    }

    function bloom(x: number, y: number) {
      if (smoothMouse.x < 0) return 0;
      const dx = x - smoothMouse.x;
      const dy = y - smoothMouse.y;
      const d2 = dx * dx + dy * dy;
      if (d2 > BLOOM_RADIUS * BLOOM_RADIUS) return 0;
      const d = Math.sqrt(d2);
      return Math.pow(1 - d / BLOOM_RADIUS, 1.8);
    }

    function roundRect(x: number, y: number, w: number, h: number, r: number) {
      ctx!.beginPath();
      ctx!.moveTo(x + r, y);
      ctx!.arcTo(x + w, y, x + w, y + r, r);
      ctx!.arcTo(x + w, y + h, x + w - r, y + h, r);
      ctx!.arcTo(x, y + h, x, y + h - r, r);
      ctx!.arcTo(x, y, x + r, y, r);
      ctx!.closePath();
    }

    function draw(now: number, intensity: number) {
      if (!geo) return;
      const t = now * 0.001;
      ctx!.clearRect(0, 0, W, H);

      const { pkg, die, blocks, pins, fieldDots, size } = geo;

      // Background field dots — sine modulation only scales with intensity
      for (const d of fieldDots) {
        const mod = 1 + 0.55 * Math.sin(t * 1.2 + d.phase) * intensity;
        const b = bloom(d.x, d.y);
        const a = Math.min(0.55, d.base * mod + b * 0.5);
        ctx!.fillStyle = rgba(BASE, a);
        ctx!.fillRect(d.x - 0.7, d.y - 0.7, 1.4, 1.4);
      }

      // Pins
      ctx!.lineCap = 'round';
      ctx!.lineWidth = 1.3;
      for (const p of pins) {
        const bx = (p.x1 + p.x2) / 2;
        const by = (p.y1 + p.y2) / 2;
        const b = bloom(bx, by);
        const mod = 1 + 0.3 * Math.sin(t * 1.8 + p.phase) * intensity;
        const a = 0.42 * mod + b * 0.6;
        ctx!.strokeStyle = rgba(BASE, a);
        ctx!.beginPath();
        ctx!.moveTo(p.x1, p.y1);
        ctx!.lineTo(p.x2, p.y2);
        ctx!.stroke();
        // Contact pad at the package edge
        ctx!.fillStyle = rgba(WARM, 0.55 + b * 0.45);
        ctx!.fillRect(p.x2 - 1.2, p.y2 - 1.2, 2.4, 2.4);
      }

      // Package outline — soft outer glow, then crisp stroke
      ctx!.shadowColor = rgba(BASE, 0.55);
      ctx!.shadowBlur = Math.max(8, size * 0.025);
      ctx!.lineWidth = 1.8;
      ctx!.strokeStyle = rgba(BASE, 0.9);
      roundRect(pkg.x, pkg.y, pkg.w, pkg.h, pkg.r);
      ctx!.stroke();
      ctx!.shadowBlur = 0;

      // Corner L-brackets (fiducials)
      const cSize = size * 0.055;
      const cOff = size * 0.02;
      ctx!.lineWidth = 2;
      ctx!.strokeStyle = rgba(WARM, 1);
      const corners: [number, number, number, number][] = [
        [pkg.x - cOff, pkg.y - cOff, 1, 1],
        [pkg.x + pkg.w + cOff, pkg.y - cOff, -1, 1],
        [pkg.x + pkg.w + cOff, pkg.y + pkg.h + cOff, -1, -1],
        [pkg.x - cOff, pkg.y + pkg.h + cOff, 1, -1],
      ];
      for (const [bx, by, dx, dy] of corners) {
        ctx!.beginPath();
        ctx!.moveTo(bx, by + dy * cSize);
        ctx!.lineTo(bx, by);
        ctx!.lineTo(bx + dx * cSize, by);
        ctx!.stroke();
      }

      // Pin-1 indicator dot
      const p1r = Math.max(2, size * 0.009);
      ctx!.fillStyle = rgba(WARM, 0.9);
      ctx!.beginPath();
      ctx!.arc(pkg.x + size * 0.05, pkg.y + size * 0.05, p1r, 0, Math.PI * 2);
      ctx!.fill();

      // Die outline + faint fill
      ctx!.lineWidth = 1.2;
      ctx!.strokeStyle = rgba(BASE, 0.55);
      roundRect(die.x, die.y, die.w, die.h, die.r);
      ctx!.fillStyle = rgba(BASE, 0.035);
      ctx!.fill();
      ctx!.stroke();

      // Internal bus lanes — horizontal + vertical channels between blocks
      ctx!.lineWidth = 0.8;
      ctx!.strokeStyle = rgba(BASE, 0.22);
      ctx!.setLineDash([4, 4]);
      ctx!.beginPath();
      // horizontal mid-bus (sits in the gap between top blocks and bottom blocks)
      const hbY = die.y + die.h * 0.6;
      ctx!.moveTo(die.x + die.w * 0.02, hbY);
      ctx!.lineTo(die.x + die.w * 0.98, hbY);
      // vertical bus between core and cache/io column
      const vbX = die.x + die.w * 0.59;
      ctx!.moveTo(vbX, die.y + die.h * 0.02);
      ctx!.lineTo(vbX, die.y + die.h * 0.58);
      // cache / io divider
      const cacheDivY = die.y + die.h * 0.3;
      ctx!.moveTo(die.x + die.w * 0.6, cacheDivY);
      ctx!.lineTo(die.x + die.w * 0.98, cacheDivY);
      ctx!.stroke();
      ctx!.setLineDash([]);

      // Functional blocks
      for (const block of blocks) {
        if (intensity > 0) block.phase += 0.013;
        block.activity *= 0.965;

        const cB = bloom(block.cx, block.cy);
        const act = Math.min(1.2, block.activity + cB * 0.7);
        const outlineA = 0.45 + 0.14 * Math.sin(block.phase) * intensity + act * 0.5;
        const fillA = 0.045 + act * 0.07;

        ctx!.fillStyle = rgba(BASE, fillA);
        ctx!.fillRect(block.x, block.y, block.w, block.h);

        ctx!.lineWidth = 1.1;
        ctx!.strokeStyle = rgba(BASE, Math.min(1, outlineA));
        ctx!.strokeRect(block.x, block.y, block.w, block.h);

        for (const d of block.dots) {
          const mod = 1 + 0.5 * Math.sin(t * 1.8 + d.phase) * intensity;
          const dB = bloom(d.x, d.y);
          const a = Math.min(1, d.base * mod + act * 0.45 + dB * 0.55);
          ctx!.fillStyle = a > 0.75 ? rgba(WARM, a) : rgba(BASE, a);
          ctx!.fillRect(d.x - 0.6, d.y - 0.6, 1.5, 1.5);
        }

        // Block label — subtle, monospaced
        if (block.w > 48 && block.h > 26) {
          const fs = Math.max(9, size * 0.02);
          ctx!.fillStyle = rgba(BASE, 0.65 + act * 0.35);
          ctx!.font = `${fs}px "JetBrains Mono", monospace`;
          ctx!.textBaseline = 'top';
          ctx!.fillText(block.label, block.x + 6, block.y + 6);
        }
      }
    }

    function tick(now: number) {
      const ageMs = now - lastActivity;
      const raw = Math.max(0, 1 - ageMs / IDLE_MS);
      const intensity = raw * raw * (3 - 2 * raw);
      draw(now, intensity);
      if (ageMs < IDLE_MS) {
        animId = requestAnimationFrame(tick);
      } else {
        running = false;
      }
    }

    function kick() {
      lastActivity = performance.now();
      if (!running) {
        running = true;
        animId = requestAnimationFrame(tick);
      }
    }

    function kickScroll() {
      if (geo) {
        const b = geo.blocks[(Math.random() * geo.blocks.length) | 0];
        b.activity = Math.min(1.3, b.activity + 0.8);
      }
      kick();
    }

    const setMouse = (clientX: number, clientY: number) => {
      const rect = canvas!.getBoundingClientRect();
      mouseToX(clientX - rect.left);
      mouseToY(clientY - rect.top);
      kick();
    };

    const clearMouse = () => {
      mouseToX(-9999);
      mouseToY(-9999);
      kick();
    };

    window.addEventListener('mousemove', e => setMouse(e.clientX, e.clientY));
    window.addEventListener('mouseout', e => {
      if (!e.relatedTarget) clearMouse();
    });
    window.addEventListener('touchmove', e => {
      const touch = e.touches[0];
      if (touch) setMouse(touch.clientX, touch.clientY);
    }, { passive: true });
    window.addEventListener('touchend', clearMouse);
    window.addEventListener('scroll', kickScroll, { passive: true });

    wrapper.querySelector('#tron-scatter-btn')?.addEventListener('click', () => {
      if (!geo) return;
      for (const b of geo.blocks) b.activity = 1;
      kick();
    });

    const ro = new ResizeObserver(() => {
      if (animId) cancelAnimationFrame(animId);
      running = false;
      resize();
      draw(performance.now(), 0);
    });
    ro.observe(wrapper);

    resize();
    draw(performance.now(), 0);
  })();
</script>
