---
interface Props {
  width?: string;
  height?: string;
  showControls?: boolean;
}

const {
  width = '100%',
  height = '500px',
  showControls = false,
} = Astro.props;
---

<div class="tron-chip-wrapper" style={`width: ${width}; height: ${height}; position: relative; background: transparent; overflow: hidden;`}>
  {showControls && (
    <div class="tron-chip-ui">
      <button class="tron-btn" id="tron-scatter-btn">SCATTER</button>
    </div>
  )}
  <canvas class="tron-chip-canvas" style="display:block; width:100%; height:100%;"></canvas>
</div>

<style>
  .tron-chip-wrapper * { box-sizing: border-box; }

  .tron-chip-ui {
    position: absolute;
    top: 12px;
    right: 12px;
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .tron-btn {
    background: transparent;
    border: 1px solid rgba(0, 212, 255, 0.25);
    color: #00d4ff;
    font-size: 10px;
    font-family: 'JetBrains Mono', monospace;
    padding: 5px 12px;
    cursor: pointer;
    letter-spacing: 2px;
    transition: background 0.2s, border-color 0.2s;
  }

  .tron-btn:hover {
    background: rgba(0, 212, 255, 0.12);
    border-color: #00d4ff;
  }
</style>

<script>
  import { gsap } from 'gsap';

  (function () {
    const wrapper = document.querySelector('.tron-chip-wrapper') as HTMLElement | null;
    const canvas  = wrapper?.querySelector('.tron-chip-canvas') as HTMLCanvasElement | null;
    if (!wrapper || !canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const palette = { main: '#00d4ff', dim: '#002633' };

    // Cursor-proximity bloom is additive over the original cyan palette
    const BLOOM_RADIUS = 170;

    // Smooth mouse position (lerped via GSAP quickTo)
    const smoothMouse = { x: -999, y: -999 };
    const targetMouse = { x: -999, y: -999 };
    const mouseToX = gsap.quickTo(smoothMouse, 'x', { duration: 0.35, ease: 'power3.out' });
    const mouseToY = gsap.quickTo(smoothMouse, 'y', { duration: 0.35, ease: 'power3.out' });

    let particles: any[] = [];
    let scattered    = false;
    let scatterTimer = 0;
    let frame        = 0;
    let animId: number | null = null;

    const CHARS = ['0', '1', 'X', 'Z', '0', '1', '0', '1'];

    function resize() {
      canvas!.width  = wrapper!.offsetWidth;
      canvas!.height = wrapper!.offsetHeight;
      initParticles();
    }

    function buildChipMask(cx: number, cy: number, scale: number) {
      const pts: { tx: number; ty: number; type: string }[] = [];
      const bw = 200 * scale;
      const bh = 220 * scale;
      const bx = cx - bw / 2;
      const by = cy - bh / 2;
      const step = 7 * scale;

      for (let x = bx + step; x < bx + bw - step; x += step) {
        for (let y = by + step; y < by + bh - step; y += step) {
          pts.push({ tx: x, ty: y, type: 'body' });
        }
      }

      const numPins  = 8;
      const pinGap   = 18 * scale;
      const pinStart = by + 28 * scale;

      for (let i = 0; i < numPins; i++) {
        const py = pinStart + i * pinGap;
        for (let px = bx - 36 * scale; px < bx; px += step) {
          pts.push({ tx: px, ty: py, type: 'pin' });
        }
        for (let px = bx + bw; px < bx + bw + 36 * scale; px += step) {
          pts.push({ tx: px, ty: py, type: 'pin' });
        }
      }

      const notchCx = bx + 18 * scale;
      const notchCy = by + 18 * scale;
      const notchR  = 14 * scale;

      return pts.filter(p => {
        const dx = p.tx - notchCx;
        const dy = p.ty - notchCy;
        return Math.sqrt(dx * dx + dy * dy) > notchR;
      });
    }

    function initParticles() {
      const W     = canvas!.width;
      const H     = canvas!.height;
      const scale = Math.min(W, H) / 420;
      const cx    = W / 2;
      const cy    = H / 2;
      const mask  = buildChipMask(cx, cy, scale);

      particles = mask.map(pt => ({
        x:      pt.tx + (Math.random() - 0.5) * W * 0.8,
        y:      pt.ty + (Math.random() - 0.5) * H * 0.8,
        tx:     pt.tx,
        ty:     pt.ty,
        vx:     0,
        vy:     0,
        char:   CHARS[Math.floor(Math.random() * CHARS.length)],
        size:   pt.type === 'pin'
                  ? 7 * scale
                  : (8 + Math.random() * 3) * scale,
        phase:  Math.random() * Math.PI * 2,
        bright: 0.3 + Math.random() * 0.7,
        type:   pt.type,
      }));
    }

    function scatter() {
      scattered    = true;
      scatterTimer = 120;
      particles.forEach(p => {
        p.vx += (Math.random() - 0.5) * 18;
        p.vy += (Math.random() - 0.5) * 18;
      });
    }

    function draw() {
      animId = requestAnimationFrame(draw);
      frame++;

      const W = canvas!.width;
      const H = canvas!.height;

      ctx!.clearRect(0, 0, W, H);

      if (scatterTimer > 0) scatterTimer--;
      if (scatterTimer === 0) scattered = false;

      const t     = frame * 0.02;
      const scale = Math.min(W, H) / 420;
      const cx    = W / 2;
      const cy    = H / 2;
      const bw    = 200 * scale;
      const bh    = 220 * scale;
      const bx    = cx - bw / 2;
      const by    = cy - bh / 2;

      ctx!.strokeStyle = palette.main + '22';
      ctx!.lineWidth   = 1;
      ctx!.strokeRect(bx, by, bw, bh);

      ctx!.beginPath();
      ctx!.arc(bx + 18 * scale, by + 18 * scale, 14 * scale, 0, Math.PI * 2);
      ctx!.stroke();

      const numPins  = 8;
      const pinGap   = 18 * scale;
      const pinStart = by + 28 * scale;

      for (let i = 0; i < numPins; i++) {
        const py = pinStart + i * pinGap;
        ctx!.beginPath(); ctx!.moveTo(bx - 36 * scale, py); ctx!.lineTo(bx, py); ctx!.stroke();
        ctx!.beginPath(); ctx!.moveTo(bx + bw, py); ctx!.lineTo(bx + bw + 36 * scale, py); ctx!.stroke();
      }

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];

        if (!scattered) {
          p.vx += (p.tx - p.x) * 0.08;
          p.vy += (p.ty - p.y) * 0.08;
        }

        p.vx *= 0.78;
        p.vy *= 0.78;
        p.x  += p.vx;
        p.y  += p.vy;

        const mdx = p.x - smoothMouse.x;
        const mdy = p.y - smoothMouse.y;
        const md  = Math.sqrt(mdx * mdx + mdy * mdy);
        const bloom = smoothMouse.x > 0 && md < BLOOM_RADIUS
          ? Math.pow(1 - md / BLOOM_RADIUS, 1.8)
          : 0;

        const pulse      = 0.6 + 0.4 * Math.sin(t * 2 + p.phase);
        const distTarget = Math.sqrt((p.x - p.tx) ** 2 + (p.y - p.ty) ** 2);
        const settled    = Math.max(0, 1 - distTarget / 40);
        const pinFactor  = p.type === 'pin' ? 0.7 : 1;
        const alpha      = Math.min(1, (p.bright * pulse * 0.5 + bloom * 0.7 + settled * 0.3) * pinFactor);

        const hexA = Math.floor(alpha * 255).toString(16).padStart(2, '0');
        ctx!.fillStyle = palette.main + hexA;
        ctx!.font      = `${p.size}px monospace`;
        ctx!.fillText(p.char, p.x - p.size * 0.3, p.y + p.size * 0.35);

        // Bloom glow layered on top of the existing cyan sparkle
        const glowLevel = Math.max(alpha > 0.7 ? alpha * 0.24 : 0, bloom * 0.55);
        if (glowLevel > 0.02) {
          const glowA = Math.floor(Math.min(1, glowLevel) * 255).toString(16).padStart(2, '0');
          ctx!.fillStyle = palette.main + glowA;
          ctx!.font      = `${p.size * 1.6}px monospace`;
          ctx!.fillText(
            p.char,
            p.x - p.size * 0.3 - p.size * 0.15,
            p.y + p.size * 0.35 + p.size * 0.15
          );
        }
      }
    }

    // Track the page cursor globally so particles react wherever the cursor is on the hero
    const setMouse = (clientX: number, clientY: number) => {
      const rect = canvas!.getBoundingClientRect();
      const scaleX = canvas!.width / rect.width;
      const scaleY = canvas!.height / rect.height;
      targetMouse.x = (clientX - rect.left) * scaleX;
      targetMouse.y = (clientY - rect.top) * scaleY;
      mouseToX(targetMouse.x);
      mouseToY(targetMouse.y);
    };

    const clearMouse = () => {
      targetMouse.x = -999;
      targetMouse.y = -999;
      mouseToX(-999);
      mouseToY(-999);
    };

    window.addEventListener('mousemove', e => setMouse(e.clientX, e.clientY));
    window.addEventListener('mouseout', e => {
      if (!e.relatedTarget) clearMouse();
    });
    window.addEventListener('touchmove', e => {
      const touch = e.touches[0];
      if (touch) setMouse(touch.clientX, touch.clientY);
    }, { passive: true });
    window.addEventListener('touchend', clearMouse);

    wrapper.querySelector('#tron-scatter-btn')?.addEventListener('click', scatter);

    const ro = new ResizeObserver(() => {
      if (animId) cancelAnimationFrame(animId);
      resize();
      draw();
    });
    ro.observe(wrapper);

    resize();
    draw();
  })();
</script>
