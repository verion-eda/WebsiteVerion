---
// Nav.astro
---

<header
    class="fixed top-0 left-0 right-0 z-50 bg-verion-bg/80 backdrop-blur-xl border-b border-verion-border/60"
>
    <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a
            href="/"
            class="font-mono font-medium text-white tracking-tight text-sm uppercase"
        >
            Verion
        </a>

        <ul
            class="hidden md:flex items-center gap-10 text-sm text-verion-muted"
        >
            <li>
                <a
                    href="#problem"
                    class="hover:text-white transition-colors duration-300"
                    >Why Verion</a>
            </li>
            <li>
                <a
                    href="#product"
                    class="hover:text-white transition-colors duration-300"
                    >Product</a>
            </li>
            <li>
                <a
                    href="#team"
                    class="hover:text-white transition-colors duration-300"
                    >Team</a>
            </li>
        </ul>

        <a
            href="#waitlist"
            class="hidden md:inline-flex items-center text-sm text-verion-accent font-mono hover:text-white transition-colors duration-300"
        >
            Get in touch &rarr;
        </a>

        <a
            href="#waitlist"
            class="md:hidden text-sm font-mono text-verion-accent"
        >
            Contact &rarr;
        </a>
    </nav>
</header>
