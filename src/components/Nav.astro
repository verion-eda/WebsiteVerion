---
// Nav.astro
---

<header
    class="fixed top-0 left-0 right-0 z-50 bg-verion-bg/70 backdrop-blur-xl"
>
    <div class="neon-line"></div>
    <nav
        class="max-w-7xl mx-auto px-8 lg:px-12 h-16 flex items-center justify-between"
    >
        <a
            href="/"
            class="group font-mono font-semibold text-[30px] leading-none flex items-baseline tracking-tight select-none"
            aria-label="Verion — home"
        >
            <span
                class="text-white group-hover:text-verion-accent transition-colors duration-300"
                style="text-shadow: 0 0 18px rgba(0, 212, 255, 0.25);"
            >verion</span>
        </a>

        <ul
            class="hidden md:flex items-center gap-10 text-sm text-verion-muted"
        >
            <li>
                <a
                    href="#problem"
                    class="hover:text-verion-accent transition-colors duration-300"
                    >Why Verion</a
                >
            </li>
            <li>
                <a
                    href="#how-it-works"
                    class="hover:text-verion-accent transition-colors duration-300"
                    >How It Works</a
                >
            </li>
            <li>
                <a
                    href="#product"
                    class="hover:text-verion-accent transition-colors duration-300"
                    >Product</a
                >
            </li>
            <li>
                <a
                    href="#team"
                    class="hover:text-verion-accent transition-colors duration-300"
                    >Team</a
                >
            </li>
        </ul>

        <a
            href="#waitlist"
            class="group hidden md:inline-flex items-center gap-2 font-mono text-sm font-semibold text-black bg-verion-accent px-5 py-2 hover:bg-verion-accent-bright transition-colors duration-200"
        >
            Request access
            <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
        </a>

        <!-- Mobile hamburger -->
        <button
            id="mobile-menu-btn"
            class="md:hidden flex flex-col gap-1.5 p-2"
            aria-label="Open menu"
            aria-expanded="false"
        >
            <span class="block w-5 h-px bg-verion-accent transition-all duration-300 origin-center" id="bar1"></span>
            <span class="block w-5 h-px bg-verion-accent transition-all duration-300" id="bar2"></span>
            <span class="block w-5 h-px bg-verion-accent transition-all duration-300 origin-center" id="bar3"></span>
        </button>
    </nav>
    <div class="neon-line opacity-30"></div>

    <!-- Mobile menu -->
    <div
        id="mobile-menu"
        class="md:hidden hidden bg-verion-bg/95 backdrop-blur-xl border-b border-verion-accent/10"
    >
        <ul class="flex flex-col px-8 py-6 gap-6 text-sm">
            <li>
                <a href="#problem" class="text-verion-muted hover:text-verion-accent transition-colors duration-300 mobile-nav-link">Why Verion</a>
            </li>
            <li>
                <a href="#how-it-works" class="text-verion-muted hover:text-verion-accent transition-colors duration-300 mobile-nav-link">How It Works</a>
            </li>
            <li>
                <a href="#product" class="text-verion-muted hover:text-verion-accent transition-colors duration-300 mobile-nav-link">Product</a>
            </li>
            <li>
                <a href="#team" class="text-verion-muted hover:text-verion-accent transition-colors duration-300 mobile-nav-link">Team</a>
            </li>
            <li>
                <a href="#waitlist" class="text-verion-accent mobile-nav-link">Request access &rarr;</a>
            </li>
        </ul>
    </div>
</header>

<script>
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const bar1 = document.getElementById("bar1");
    const bar2 = document.getElementById("bar2");
    const bar3 = document.getElementById("bar3");

    let open = false;

    btn?.addEventListener("click", () => {
        open = !open;
        menu?.classList.toggle("hidden", !open);
        btn.setAttribute("aria-expanded", String(open));

        if (open) {
            bar1?.classList.add("translate-y-[4px]", "rotate-45");
            bar2?.classList.add("opacity-0");
            bar3?.classList.add("-translate-y-[4px]", "-rotate-45");
        } else {
            bar1?.classList.remove("translate-y-[4px]", "rotate-45");
            bar2?.classList.remove("opacity-0");
            bar3?.classList.remove("-translate-y-[4px]", "-rotate-45");
        }
    });

    // Close menu when clicking a link
    document.querySelectorAll(".mobile-nav-link").forEach((link) => {
        link.addEventListener("click", () => {
            open = false;
            menu?.classList.add("hidden");
            btn?.setAttribute("aria-expanded", "false");
            bar1?.classList.remove("translate-y-[4px]", "rotate-45");
            bar2?.classList.remove("opacity-0");
            bar3?.classList.remove("-translate-y-[4px]", "-rotate-45");
        });
    });
</script>
